{
    "name": "@tailwindest/compiler",
    "version": "0.0.1",
    "description": "Zero-runtime CSS-in-JS compiler for tailwindest",
    "type": "module",
    "main": "dist/index.mjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "author": "danpacho",
    "license": "MIT",
    "homepage": "https://tailwindest.vercel.app",
    "repository": {
        "type": "git",
        "url": "https://github.com/danpacho/tailwindest",
        "directory": "packages/compiler"
    },
    "keywords": [
        "tailwindcss",
        "tailwind",
        "css-in-js",
        "compiler",
        "vite",
        "zero-runtime"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./vite": {
            "types": "./dist/vite/index.d.mts",
            "import": "./dist/vite/index.mjs"
        },
        "./package.json": {
            "default": "./package.json"
        }
    },
    "scripts": {
        "build": "tsup && node -e \"const fs=require('node:fs'); for (const file of ['dist/index','dist/vite/index']) if (fs.existsSync(file+'.d.ts')) fs.copyFileSync(file+'.d.ts', file+'.d.mts')\"",
        "test": "vitest run",
        "test:e2e": "vitest run e2e",
        "e2e:vite-tailwind-v4": "vitest run e2e/vite-tailwind-v4",
        "e2e:design-system-vite": "vitest run e2e/design-system-vite",
        "e2e:design-system-tanstack-start": "vitest run e2e/design-system-tanstack-start",
        "e2e:design-system-next": "vitest run e2e/design-system-next",
        "e2e:design-system": "vitest run e2e/design-system-vite e2e/design-system-tanstack-start e2e/design-system-next",
        "e2e:tanstack-start": "vitest run e2e/tanstack-start-tailwind-v4",
        "e2e:next": "vitest run e2e/next-tailwind-v4",
        "e2e:frameworks": "vitest run e2e/tanstack-start-tailwind-v4 e2e/next-tailwind-v4",
        "dev": "tsup --watch",
        "prepack": "pnpm run build",
        "pack:dry": "npm pack --dry-run"
    },
    "dependencies": {
        "typescript": "^5.5.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "tailwindcss": ">=4.0.0",
        "vite": ">=8.0.0"
    },
    "peerDependenciesMeta": {
        "tailwindcss": {
            "optional": true
        },
        "vite": {
            "optional": true
        }
    },
    "devDependencies": {
        "@playwright/test": "1.59.1",
        "@tailwindcss/postcss": "4.2.4",
        "@tailwindcss/vite": "^4.2.4",
        "@tanstack/react-router": "1.168.25",
        "@tanstack/react-start": "1.167.50",
        "@tanstack/router-plugin": "1.167.28",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.1",
        "next": "16.2.4",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "tailwindcss": "^4.2.4",
        "tsx": "4.21.0",
        "vite": "^8.0.10"
    }
}
