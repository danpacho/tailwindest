{
    "name": "@tailwindest/compiler",
    "version": "1.0.0",
    "private": true,
    "description": "Deprecated internal Tailwindest compiler experiment; not published",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "author": "danpacho",
    "license": "MIT",
    "homepage": "https://tailwindest.vercel.app",
    "repository": {
        "type": "git",
        "url": "https://github.com/danpacho/tailwindest",
        "directory": "packages/compiler"
    },
    "keywords": [
        "tailwindcss",
        "tailwind",
        "css-in-js",
        "compiler",
        "vite"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./vite": {
            "types": "./dist/vite/index.d.ts",
            "import": "./dist/vite/index.js"
        },
        "./package.json": {
            "default": "./package.json"
        }
    },
    "scripts": {
        "build": "tsup",
        "test": "vitest run src && pnpm run test:e2e",
        "test:e2e": "pnpm run e2e:vite-tailwind-v4 && pnpm run e2e:tanstack-start && pnpm run e2e:next && pnpm run e2e:design-system-vite && pnpm run e2e:design-system-tanstack-start && pnpm run e2e:design-system-next",
        "e2e:vite-tailwind-v4": "vitest run e2e/vite-tailwind-v4",
        "e2e:design-system-vite": "vitest run e2e/design-system-vite",
        "e2e:design-system-tanstack-start": "vitest run e2e/design-system-tanstack-start",
        "e2e:design-system-next": "vitest run e2e/design-system-next",
        "e2e:design-system": "vitest run e2e/design-system-vite e2e/design-system-tanstack-start e2e/design-system-next",
        "e2e:tanstack-start": "vitest run e2e/tanstack-start-tailwind-v4",
        "e2e:next": "vitest run e2e/next-tailwind-v4",
        "e2e:frameworks": "vitest run e2e/tanstack-start-tailwind-v4 e2e/next-tailwind-v4",
        "dev": "tsup --watch",
        "prepack": "pnpm run build",
        "prepublishOnly": "node -e \"throw new Error('@tailwindest/compiler is deprecated and private; do not publish')\"",
        "pack:dry": "npm pack --dry-run"
    },
    "dependencies": {
        "@tailwindest/core": "workspace:*",
        "@tailwindest/tailwind-internal": "workspace:*",
        "typescript": "^5.5.0"
    },
    "peerDependencies": {
        "tailwindcss": ">=4.0.0",
        "vite": ">=8.0.0"
    },
    "peerDependenciesMeta": {
        "tailwindcss": {
            "optional": true
        },
        "vite": {
            "optional": true
        }
    },
    "devDependencies": {
        "@playwright/test": "1.59.1",
        "@tailwindcss/postcss": "4.2.4",
        "@tailwindcss/vite": "^4.2.4",
        "@tanstack/react-router": "1.168.25",
        "@tanstack/react-start": "1.167.50",
        "@tanstack/router-plugin": "1.167.28",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.1",
        "next": "16.2.4",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "tailwindcss": "^4.2.4",
        "tsx": "4.21.0",
        "vite": "^8.0.10"
    }
}
