{
    "compilerOptions": {
        "strict": true,
        "target": "esnext",
        "module": "esnext",
        "lib": ["dom", "dom.iterable", "esnext"],
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "outDir": "dist",
        "rootDir": "src",
        "types": ["node"]
    },
    "include": ["src"],
    "exclude": ["src/**/__tests__/**"]
}
