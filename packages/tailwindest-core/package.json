{
    "name": "tailwindest-core",
    "version": "1.0.1",
    "description": "Pure semantic helpers for Tailwindest runtime behavior",
    "private": false,
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": {
            "default": "./package.json"
        }
    },
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "prepack": "pnpm build"
    },
    "dependencies": {
        "clsx": "^2.1.1"
    },
    "publishConfig": {
        "access": "public"
    }
}
