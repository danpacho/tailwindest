{
    "name": "create-tailwind-type",
    "version": "1.1.4",
    "description": "Type generator for tailwindcss.",
    "type": "module",
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "build:fast": "tsup --no-dts",
        "format": "prettier --write \"./{src,tests}/**/*\"",
        "dev": "pnpm build:fast --sourcemap --clean=false --watch",
        "test": "vitest run --config ./vitest.config.ts",
        "prepack": "pnpm build && node ./src/site_extractor/build.mjs",
        "prepublishOnly": "pnpm test",
        "lint:ts": "tsc --noEmit",
        "publish:verify": "pnpm prepublishOnly && pnpm pack --json && npm publish --dry-run --ignore-scripts --access public"
    },
    "publishConfig": {
        "access": "public"
    },
    "bin": {
        "create-tailwind-type": "dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "keywords": [],
    "private": false,
    "author": "danpacho",
    "license": "MIT",
    "dependencies": {
        "tailwindest-tailwind-internal": "^1.0.2",
        "boxen": "^8.0.1",
        "chalk": "^5.4.1",
        "commander": "^14.0.3",
        "@clack/prompts": "^1.2.0",
        "picocolors": "^1.1.0",
        "postcss": "^8.5.3",
        "prettier": "^3.5.2",
        "prettier-plugin-jsdoc": "^1.3.2",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "@types/jsdom": "^28.0.1",
        "jsdom": "^29.1.0"
    }
}
