{
    "name": "@tailwindest/tailwind-internal",
    "version": "0.0.1",
    "description": "Shared internal Tailwind CSS integration utilities for Tailwindest packages",
    "type": "module",
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        },
        "./package.json": {
            "default": "./package.json"
        }
    },
    "scripts": {
        "build": "tsup",
        "test": "vitest run"
    },
    "dependencies": {
        "@tailwindcss/node": "^4.2.4",
        "glob": "^13.0.6",
        "lightningcss": "^1.29.1",
        "tailwindcss": "^4.2.4"
    },
    "publishConfig": {
        "access": "public"
    }
}
