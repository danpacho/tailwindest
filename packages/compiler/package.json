{
    "name": "@tailwindest/compiler",
    "version": "0.0.1",
    "description": "Zero-runtime CSS-in-JS compiler for tailwindest",
    "type": "module",
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./vite": {
            "types": "./dist/vite/index.d.mts",
            "import": "./dist/vite/index.mjs"
        }
    },
    "scripts": {
        "build": "tsup && node -e \"const fs=require('node:fs'); for (const file of ['dist/index','dist/vite/index']) if (fs.existsSync(file+'.d.ts')) fs.copyFileSync(file+'.d.ts', file+'.d.mts')\"",
        "test": "vitest run",
        "test:e2e": "vitest run e2e",
        "e2e:vite-tailwind-v4": "vitest run e2e/vite-tailwind-v4",
        "dev": "tsup --watch"
    },
    "dependencies": {
        "ts-morph": "^24.0.0",
        "create-tailwind-type": "workspace:*"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.4",
        "tsup": "^8.2.0",
        "typescript": "^5.5.0",
        "tailwindcss": "^4.2.4",
        "vite": "^8.0.10",
        "vitest": "^2.0.0"
    }
}
