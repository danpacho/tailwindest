{
    "compilerOptions": {
        "strict": true,
        "target": "esnext",
        "module": "esnext",
        "lib": ["dom", "dom.iterable", "esnext"],
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "paths": {
            "tailwindest": ["./packages/tailwindest/src/index.ts"],
            "tailwindest/*": ["./packages/tailwindest/src/*"]
        }
    },
    "include": ["packages"],
    "exclude": ["node_modules", "dist", "site", "examples"]
}
