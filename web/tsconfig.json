{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "incremental": true,
        "jsx": "preserve",
        "lib": ["dom", "dom.iterable", "esnext"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "paths": {
            "@/*": ["./*"],
            "collections/*": ["./.source/*"]
        },
        "plugins": [
            {
                "name": "next"
            }
        ],
        "resolveJsonModule": true
    },
    "include": [
        "next-env.d.ts",
        ".source/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "components/**/*.ts",
        "components/**/*.tsx",
        "content/**/*.mdx",
        "lib/**/*.ts",
        "lib/**/*.tsx",
        "*.ts",
        "*.tsx",
        "*.mts"
    ],
    "exclude": ["node_modules", ".next", "dist"]
}
